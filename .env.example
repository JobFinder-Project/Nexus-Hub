# Porta do seu aplicativo
PORT=8080

# URL do servidor do banco de dados
DB_HOST=127.0.0.1

# Usuário do servidor do banco
DB_USER=example_user

# Senha do usuário do banco (apenas exemplo — não use em produção)
DB_PASS=example_password

# Nome do banco de dados
DB_NAME=nexus_db_example

# Segredo da sessão (use uma string longa e secreta em produção)
SESSION_SECRET=example_session_secret_change_me