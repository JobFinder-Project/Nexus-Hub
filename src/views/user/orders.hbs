<link rel="stylesheet" href="/css/orders.css">

<div class="profile-container">
  
  <div class="profile-wrapper">
    <!-- Sidebar de Navegação do Perfil -->
    <aside class="profile-sidebar">
      <div class="profile-header">
        <div class="profile-avatar">
          <i class="fas fa-user-circle"></i>
        </div>
        <div class="profile-info">
          <h2 class="profile-name">{{session.userName}}</h2>
        </div>
      </div>

      <nav class="profile-menu">
        <a href="/profile/account" class="profile-menu-item">
          <i class="fas fa-user"></i>
          <span>Detalhes da Conta</span>
        </a>
        <a href="/library" class="profile-menu-item">
          <i class="fas fa-gamepad"></i>
          <span>Minha Biblioteca</span>
        </a>
        <a href="/profile/orders" class="profile-menu-item active">
          <i class="fas fa-box-open"></i>
          <span>Meus Pedidos</span>
        </a>
        <a href="/cart" class="profile-menu-item">
          <i class="fas fa-shopping-cart"></i>
          <span>Meu Carrinho</span>
        </a>
        <a href="/settings" class="profile-menu-item">
          <i class="fas fa-cog"></i>
          <span>Configurações</span>
        </a>
      </nav>

      <div class="profile-footer">
        <small class="text-muted">
          <i class="fas fa-info-circle"></i>
          Histórico de compras
        </small>
      </div>
    </aside>

    <!-- Conteúdo Principal -->
    <main class="profile-content">
      <div class="profile-section">
        <div class="section-header">
          <h1 class="section-title">
            <i class="fas fa-box-open"></i>
            Meus Pedidos
          </h1>
          <p class="section-subtitle">Acompanhe o histórico de todas as suas compras</p>
        </div>

        {{#if hasOrders}}
          <!-- Lista de Pedidos -->
          <div class="orders-container">
            {{#each orders}}
              <div class="order-card">
                <!-- Header do Pedido -->
                <div class="order-header">
                  <div class="order-info">
                    <div class="order-number">
                      <span class="label">Pedido #</span>
                      <span class="value">{{this.id}}</span>
                    </div>
                    <div class="order-date">
                      <i class="fas fa-calendar-alt"></i>
                      <span>{{this.data_compra}}</span>
                    </div>
                  </div>

                  <div class="order-status">
                    <span class="status-badge status-{{this.status_badge}}">
                      <i class="fas fa-{{#if (eq this.status_badge 'success')}}check-circle{{else if (eq this.status_badge 'warning')}}hourglass-half{{else}}times-circle{{/if}}"></i>
                      {{this.status_label}}
                    </span>
                  </div>
                </div>

                <!-- Items do Pedido -->
                <div class="order-items">
                  {{#each this.itens}}
                    <div class="order-item">
                      <!-- Imagem do Produto -->
                      <div class="item-image">
                        <img src="{{this.cover}}" alt="{{this.titulo}}" onerror="this.src='https://placehold.co/80x100/1a1a1a/fff?text=GAME'">
                      </div>

                      <!-- Informações do Item -->
                      <div class="item-details">
                        <h4 class="item-title">
                          <a href="/catalog/product/{{this.slug}}" title="Ver produto">{{this.titulo}}</a>
                        </h4>
                        <span class="item-price">{{formatPrice this.preco_na_compra}}</span>
                        {{#if this.chave_revelada_em}}
                          <span class="item-delivered">
                            <i class="fas fa-check"></i>
                            Chave entregue
                          </span>
                        {{/if}}
                      </div>

                      <!-- Ação -->
                      <div class="item-action">
                        {{#if (eq ../status_badge 'success')}}
                          <a href="/library/keys/{{../id}}" class="btn-view-key" title="Ver chave de ativação">
                            <i class="fas fa-key"></i>
                            Ver Chave
                          </a>
                        {{else}}
                          <button class="btn-view-key" disabled title="Pedido ainda não foi aprovado">
                            <i class="fas fa-lock"></i>
                            Bloqueado
                          </button>
                        {{/if}}
                      </div>
                    </div>
                  {{/each}}
                </div>

                <!-- Footer do Pedido -->
                <div class="order-footer">
                  <div class="order-summary">
                    <span class="summary-label">{{this.quantidade_itens}} item(ns)</span>
                    <span class="summary-divider">•</span>
                    <span class="summary-total">
                      Total: <strong>{{formatPrice this.preco_total}}</strong>
                    </span>
                  </div>

                  <div class="order-actions">
                    {{#if (eq this.status_badge 'success')}}
                      <a href="/library" class="btn-secondary btn-sm">
                        <i class="fas fa-gamepad"></i>
                        Ir à Biblioteca
                      </a>
                    {{/if}}
                    <button class="btn-details btn-sm" onclick="toggleOrderDetails({{this.id}})">
                      <i class="fas fa-chevron-down"></i>
                      Detalhes
                    </button>
                  </div>
                </div>

                <!-- Detalhes Expandidos (oculto por padrão) -->
                <div class="order-details" id="details-{{this.id}}" style="display: none;">
                  <div class="details-content">
                    <div class="detail-row">
                      <span class="detail-label">Data e Hora:</span>
                      <span class="detail-value">{{this.data_compra}}</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Status do Pagamento:</span>
                      <span class="detail-value">
                        <span class="status-badge status-{{this.status_badge}}">{{this.status_label}}</span>
                      </span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Número de Itens:</span>
                      <span class="detail-value">{{this.quantidade_itens}}</span>
                    </div>
                    <div class="detail-row">
                      <span class="detail-label">Valor Total:</span>
                      <span class="detail-value highlight">{{formatPrice this.preco_total}}</span>
                    </div>
                    {{#if (eq this.status_badge 'pending')}}
                      <div class="detail-info-box">
                        <i class="fas fa-info-circle"></i>
                        <p>Seu pagamento está sendo processado. Você receberá as chaves assim que a transação for confirmada.</p>
                      </div>
                    {{/if}}
                    {{#if (eq this.status_badge 'danger')}}
                      <div class="detail-warning-box">
                        <i class="fas fa-exclamation-triangle"></i>
                        <p>Seu pagamento foi recusado. Por favor, tente novamente ou entre em contato com o suporte.</p>
                      </div>
                    {{/if}}
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        {{else}}
          <!-- Estado Vazio -->
          <div class="empty-state">
            <div class="empty-icon">
              <i class="fas fa-inbox"></i>
            </div>
            <h2 class="empty-title">Nenhum pedido realizado</h2>
            <p class="empty-message">Você ainda não realizou nenhuma compra. Comece a explorar nosso catálogo e faça seu primeiro pedido!</p>
            <a href="/catalog" class="btn btn-primary btn-lg">
              <i class="fas fa-shopping-bag"></i>
              Explorar Catálogo
            </a>
          </div>
        {{/if}}
      </div>
    </main>
  </div>
</div>

<script>
  function toggleOrderDetails(orderId) {
    const detailsElement = document.getElementById(`details-${orderId}`);
    if (detailsElement) {
      const isVisible = detailsElement.style.display !== 'none';
      detailsElement.style.display = isVisible ? 'none' : 'block';
    }
  }
</script>