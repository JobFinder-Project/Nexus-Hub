<div class='kpi-grid'>
  {{#each kpis}}
    <div class='kpi-card'>
      <div class='kpi-icon-box {{this.color}}'><i class='fas fa-{{this.icon}}'></i></div>
      <div><span class='kpi-value'>{{this.value}}</span><span
          class='kpi-label'
        >{{this.label}}</span></div>
    </div>
  {{/each}}
</div>

<div
  class='dash-layout-split'
  style='display: grid; grid-template-columns: 2fr 1fr; gap: 20px; margin-bottom: 30px;'
>

  <div class='dash-table-card' style='padding: 20px;'>
    <div class='card-header' style='border: none; padding: 0 0 20px 0;'>
      <h3><i class='fas fa-chart-area'></i> Desempenho Mensal</h3>
    </div>
    <div style='height: 300px; width: 100%;'>
      <canvas id='salesChart'></canvas>
    </div>
  </div>

  <div style='display: flex; flex-direction: column; gap: 20px;'>

    {{#if (eq userRole 'parceiro')}}
      <div class='dash-table-card'>
        <div class='card-header'>
          <h3 style='color: var(--danger); font-size: 1rem;'><i
              class='fas fa-exclamation-triangle'
            ></i>
            Estoque Baixo</h3>
        </div>
        <table class='clean-table'>
          <tbody>
            {{#each lowStockItems}}
              <tr>
                <td>{{this.title}}</td>
                <td
                  style='text-align: right; color: var(--danger); font-weight: bold;'
                >{{this.keysLeft}} un.</td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <div class='dash-table-card'>
        <div class='card-header'>
          <h3 style='font-size: 1rem;'><i class='fas fa-bolt'></i> Promoções Ativas</h3>
        </div>
        <table class='clean-table'>
          <tbody>
            {{#each activePromotions}}
              <tr>
                <td>{{this.product}}</td>
                <td><span class='status-pill success'>-{{this.discount}}</span></td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

    {{#if (eq userRole 'admin')}}
      <div class='dash-table-card'>
        <div class='card-header'>
          <h3 style='font-size: 1rem;'><i class='fas fa-history'></i> Pendências</h3>
        </div>
        <table class='clean-table'>
          <tbody>
            {{#each pendingApprovals}}
              <tr>
                <td><small>{{this.type}}</small><br /><strong>{{this.name}}</strong></td>
                <td style='text-align: right;'><a
                    href='#'
                    onclick="openModal('approvalsModal'); return false;"
                    style='color: var(--primary);'
                  >Ver</a></td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>

      <div class='dash-table-card'>
        <div class='card-header'>
          <h3 style='font-size: 1rem;'><i class='fas fa-bolt'></i> Campanhas Ativas</h3>
        </div>
        <table class='clean-table'>
          <tbody>
            {{#each activePromotions}}
              <tr>
                <td>{{this.title}}<br /><small>{{this.product}}</small></td>
                <td><span class='status-pill success'>-{{this.discount}}</span></td>
              </tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    {{/if}}

  </div>
</div>

{{#if (eq userRole 'parceiro')}}
  <div id='salesModal' class='nh-modal-overlay'>
    <div class='nh-modal-box modal-lg'>
      <div class='nh-modal-header'>
        <h3>Relatório Detalhado de Vendas</h3>
        <button onclick="closeModal('salesModal')" class='btn-close-modal'>&times;</button>
      </div>
      <div class='nh-modal-body'>
        <table class='clean-table'>
          <thead><tr><th>Data</th><th>Produto</th><th>Valor</th><th>Status</th></tr></thead>
          <tbody>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div id='promoModal' class='nh-modal-overlay'>
    <div class='nh-modal-box'>
      <div class='nh-modal-header'>
        <h3>Criar Nova Promoção</h3>
        <button onclick="closeModal('promoModal')" class='btn-close-modal'>&times;</button>
      </div>
      <form class='nh-modal-body'>
        <div class='form-group'>
          <label class='form-label'>Selecione o Jogo</label>
          <select class='form-control'><option>Elden Ring</option><option>God of War</option></select>
        </div>
        <div class='form-group'>
          <label class='form-label'>Desconto (%)</label>
          <input type='number' class='form-control' placeholder='Ex: 20' />
        </div>
        <button class='btn-dash btn-dash-primary' style='width: 100%;'>Ativar Oferta</button>
      </form>
    </div>
  </div>
{{/if}}

{{#if (eq userRole 'admin')}}

  {{> dashboard-modals }}

{{/if}}

<script src='https://cdn.jsdelivr.net/npm/chart.js'></script>
<script>
  document.addEventListener('DOMContentLoaded', function() { const ctx =
  document.getElementById('salesChart').getContext('2d'); const chartData =
  {{{chartData}}}; new Chart(ctx, { type: 'line', data: chartData, options: { responsive: true,
  maintainAspectRatio: false, plugins: { legend: { position: 'top' } }, scales: { y: { beginAtZero:
  true, grid: { color: '#f0f0f0' } }, x: { grid: { display: false } } } } }); });
</script>