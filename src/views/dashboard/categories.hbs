<div class="dash-table-card">
    <div class="card-header">
        <h3><i class="fas fa-layer-group"></i> Plataformas & Categorias</h3>
        <button onclick="openModal('catModal')" class="btn-dash btn-dash-primary">
            <i class="fas fa-plus"></i> Adicionar
        </button>
    </div>

    <table class="clean-table">
        <thead>
            <tr>
                <th>Nome</th>
                <th>Slug</th>
                <th>Ações</th>
            </tr>
        </thead>
        <tbody>
            {{#each platforms}}
            <tr>
                <td>{{this.nome}}</td>
                <td><code>{{this.slug}}</code></td>
                <td><a href="#"><i class="fas fa-trash"></i></a></td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>

<div id="catModal" class="nh-modal-overlay">
    <div class="nh-modal-box">
        <div class="nh-modal-header">
            <h3>Nova Plataforma</h3>
            <button onclick="closeModal('catModal')" class="btn-close-modal">&times;</button>
        </div>
        <div class="nh-modal-body">
            <form action="/admin/plataforms/create" method="POST">
                <div class="form-group">
                    <label class="form-label">Nome</label>
                    <input type="text" name="nome" class="form-control" placeholder="Ex: PlayStation 6">
                </div>
                <div class="form-group">
                    <label class="form-label">Slug</label>
                    <input type="text" name="slug" class="form-control" placeholder="ex: ps6">
                </div>
                <button type="submit" class="btn-dash btn-dash-primary full-width">Adicionar</button>
            </form>
        </div>

        <div class="modal-list-container">
            <h4>Existentes</h4>
            <ul class="simple-list">
                {{#if platforms}}
                {{#each platforms}}
                <li>
                    {{this.nome}} <small><code>{{this.slug}}</code></small>
                    <form action="/admin/plataforms/delete/{{this.id}}" method="POST" style="display:inline;">
                        <button class="btn-icon-danger" title="Remover"><i class="fas fa-trash"></i></button>
                    </form>
                </li>
                {{/each}}
                {{else}}
                <li>Nenhuma plataforma cadastrada.</li>
                {{/if}}
            </ul>
        </div>
    </div>
</div>